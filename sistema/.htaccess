Options -Indexes

<IfModule mod_authz_core.c>
    <FilesMatch "(?i)\.(sql|bak|backup|old|log|ini|env)$">
        Require all denied
    </FilesMatch>
</IfModule>

<IfModule !mod_authz_core.c>
    <FilesMatch "(?i)\.(sql|bak|backup|old|log|ini|env)$">
        Order allow,deny
        Deny from all
    </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(?:logs?|backups?)/ - [F,L,NC]
</IfModule>
